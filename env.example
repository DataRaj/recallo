# ── Recallo — Environment Configuration Example ──────────────────────────────
# Copy this file to config/dev.env (or config/prod.env) and fill in real values.
# The config/ directory is gitignored — never commit real secrets.

ENV=dev

# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/gotel?sslmode=disable

# Redis connection string (bound to loopback in production)
REDIS_URL=redis://127.0.0.1:6379/0

# HTTP server bind address
HTTP_ADDRESS=0.0.0.0:8080

# JWT signing key — use a long random string in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret

# ── OAuth: GitHub (Development) ──────────────────────────────────────────────
# Create these secrets in Settings → Developer settings → OAuth Apps
# (set http://localhost:8000 as Callback URL in the app settings)

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Deepgram STT ──────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
DEEPGRAM_TIMEOUT_SEC=120

# ── DigitalOcean Spaces (recording storage) ───────────────────────────────────
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=airstage-recordings
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key