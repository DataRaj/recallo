### ══════════════════════════════════════════════════════════
###  CONVERSATIONS  (protected)
### ══════════════════════════════════════════════════════════

# ✅ Get all conversations for the current user
GET {{baseUrl}}/conversations
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

###

# ✅ Join (or create) a private conversation
POST {{baseUrl}}/conversation/private/create
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

{
  "receiver_id": 2
}

###

# ✅ Get a specific private conversation by ID
GET {{baseUrl}}/conversation/private/1
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

###

# ❌ Non-existent conversation
GET {{baseUrl}}/conversation/private/99999
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}


### ══════════════════════════════════════════════════════════
###  MESSAGES  (protected)
### ══════════════════════════════════════════════════════════

# ✅ Get messages — default pagination (page=1, limit=20)
GET {{baseUrl}}/conversation/private/1/messages
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

###

# ✅ Get messages — custom pagination
GET {{baseUrl}}/conversation/private/1/messages?page=2&limit=10
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

###

# ❌ Limit exceeds max (100)
GET {{baseUrl}}/conversation/private/1/messages?limit=200
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

###

# ❌ Invalid page number
GET {{baseUrl}}/conversation/private/1/messages?page=0
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}


### ══════════════════════════════════════════════════════════
###  FILES  (protected)
### ══════════════════════════════════════════════════════════

# ✅ Upload a file to a private conversation
# Replace <private_id> with a real ID, and attach a file via multipart form.
# In HTTP clients like Bruno or Insomnia, set body to multipart/form-data
# with field key "file" pointing to your local file.
POST {{baseUrl}}/files/1
Content-Type: multipart/form-data; boundary=----FormBoundary
X-Platform: web
Authorization: Bearer {{accessToken}}

------FormBoundary
Content-Disposition: form-data; name="file"; filename="test.txt"
Content-Type: text/plain

Hello from Recallo file upload test.
------FormBoundary--

###

# ✅ Retrieve an uploaded file (static file server)
# Replace path with an actual file_url returned from upload response.
GET {{baseUrl}}/files/chats/1/1/test.txt
X-Platform: web
Authorization: Bearer {{accessToken}}


### ══════════════════════════════════════════════════════════
###  WEBSOCKET  (GET /api/v1/ws)
###
###  REST clients cannot open WebSocket connections directly.
###  Use one of the options below instead:
###
###  ① websocat (CLI):
###      websocat -H "Authorization: Bearer <token>" \
###               ws://localhost:8080/api/v1/ws
###
###  ② Postman / Insomnia:
###      URL : ws://localhost:8080/api/v1/ws
###      Header: Authorization: Bearer <token>
###
###  ─────────────────────────────────────────────────────────
###  All payloads are JSON. Send:  { "event_type": "...", "payload": { ... } }
###  Receive:                      { "event_type": "...", "payload": { ... } }
###
###  Event types emitted BY the server:
###    current_user   — list of currently online users (on connect)
###    online         — a user came online
###    offline        — a user went offline
###    message        — new chat message
###    delivered      — message delivery confirmed
###    read           — message read confirmed
###    typing         — typing indicator
###    heartbeat      — keep-alive ping every 30 s (payload: null)
###    error          — operation failed  { "message": "..." }
###    shutdown       — server is shutting down
###
###  Event types accepted FROM the client:
### ══════════════════════════════════════════════════════════

# ── Send a text message ─────────────────────────────────────
# event_type : "message"
# Required payload fields:
#   private_id   int   — conversation ID
#   receiver_id  int   — recipient user ID
#   message_type string — "text" | "image" | "file"
#   content      string — message body
#
# Example (paste into websocat / Postman message body):
# {
#   "event_type": "message",
#   "payload": {
#     "private_id":   1,
#     "receiver_id":  2,
#     "message_type": "text",
#     "content":      "Hey, what's up?"
#   }
# }

###

# ── Mark a message as delivered ─────────────────────────────
# event_type : "delivered"
# {
#   "event_type": "delivered",
#   "payload": {
#     "message_id": 42
#   }
# }

###

# ── Mark a message as read ───────────────────────────────────
# event_type : "read"
# {
#   "event_type": "read",
#   "payload": {
#     "message_id": 42
#   }
# }

###

# ── Send a typing indicator ──────────────────────────────────
# event_type : "typing"
# {
#   "event_type": "typing",
#   "payload": {
#     "private_id":  1,
#     "receiver_id": 2,
#     "is_typing":   true
#   }
# }


