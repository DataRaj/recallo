### ══════════════════════════════════════════════════════════
###  AUTH — REGISTER
### ══════════════════════════════════════════════════════════

# ✅ Happy path — new user
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "name": "Dattaraj",
  "email": "datta@example.com",
  "password": "secret123"
}

###

# ❌ Duplicate email
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "name": "Yash",
  "email": "yash@example.com",
  "password": "secret123"
}

###

# ❌ Missing required fields
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "email": "datta@example.com"
}


### ══════════════════════════════════════════════════════════
###  AUTH — LOGIN
### ══════════════════════════════════════════════════════════

# ✅ Happy path — web platform
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}
X-Platform: web

{
  "email": "[EMAIL_ADDRESS]",
  "password": "[PASSWORD]"
}

###

# ✅ Happy path — mobile platform
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}
X-Platform: mobile

{
  "email": "datta@example.com",
  "password": "secret123"
}

###

# ❌ Wrong password
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}
X-Platform: web

{
  "email": "datta@example.com",
  "password": "wrongpass"
}

###

# ❌ Missing X-Platform header
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "datta@example.com",
  "password": "secret123"
}

###

# ❌ Missing email/password body
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}
X-Platform: web

{
  "email": ""
}


### ══════════════════════════════════════════════════════════
###  AUTH — REFRESH SESSION
### ══════════════════════════════════════════════════════════

# ✅ Happy path — paste refresh_token from login response
POST {{baseUrl}}/auth/refresh-session
Content-Type: {{contentType}}
X-Platform: web

{
  "refresh_token": "{{refreshToken}}"
}

###

# ❌ Invalid/expired token
POST {{baseUrl}}/auth/refresh-session
Content-Type: {{contentType}}
X-Platform: web

{
  "refresh_token": "invalid.token.value"
}

###

# ❌ Missing X-Platform header
POST {{baseUrl}}/auth/refresh-session
Content-Type: {{contentType}}

{
  "refresh_token": "{{refreshToken}}"
}


### ══════════════════════════════════════════════════════════
###  AUTH — LOGOUT  (protected)
### ══════════════════════════════════════════════════════════

# ✅ Happy path
POST {{baseUrl}}/auth/logout
Content-Type: {{contentType}}
X-Platform: web
Authorization: Bearer {{accessToken}}

###

# ❌ No token
POST {{baseUrl}}/auth/logout
Content-Type: {{contentType}}
X-Platform: web

###

# ❌ Platform mismatch (token issued for web, sending mobile)
POST {{baseUrl}}/auth/logout
Content-Type: {{contentType}}
X-Platform: mobile
Authorization: Bearer {{accessToken}}


### ══════════════════════════════════════════════════════════
