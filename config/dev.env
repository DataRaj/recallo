
ENV=dev

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recallo?sslmode=disable

# ── HTTP Server ───────────────────────────────────────────────────────────────
HTTP_ADDRESS=0.0.0.0:8080

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=sha25612864321684210

# ── OAuth: GitHub ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=Ov23lifPzX6rfTvHRFde
GITHUB_CLIENT_SECRET=0b4d711b1db158ee3e0917230281f9076df47430
GITHUB_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# ── AI / Speech ───────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=99289faa344b5cc495c68dc48af8460468899653

# ── LiveKit (WebRTC SFU) ──────────────────────────────────────────────────────
# Obtain all three values from: https://cloud.livekit.io → your project → Settings
#
#   LIVEKIT_HOST        — WebSocket URL of your LiveKit Cloud project
#                         e.g. wss://your-project.livekit.cloud
#
#   LIVEKIT_API_KEY     — API key used to sign tokens and call Room Service
#                         e.g. APIxxxxxxxxxxxxxxxx
#
#   LIVEKIT_API_SECRET  — Paired secret for LIVEKIT_API_KEY (keep private!)
#                         Used for JWT signing AND outbound Room Service calls.
#
#   LIVEKIT_WEBHOOK_SECRET — Separate secret configured in LiveKit Cloud console
#                            under Settings → Webhooks, used to validate inbound
#                            webhook HMAC signatures. Different from API secret.
#
LIVEKIT_HOST=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_WEBHOOK_SECRET=your_livekit_webhook_secret_here

# ── Non-Login (Guest) Tier Limits ────────────────────────────────────────────
# Controls applied at token-generation time for unauthenticated (guest) users.
#
#   GUEST_MAX_PARTICIPANTS — Hard cap on participants per room for guest tier.
#                            LiveKit room is created with this as max_participants.
#                            Defense-in-depth: enforced at both token gen AND room config.
#
#   GUEST_SESSION_DURATION_MINS — Max call/stream duration (minutes) for guest rooms.
#                                  A background job ends the room when this elapses.
#                                  Guests may POST /rooms/:id/extend once to get more time.
#
#   GUEST_MAX_VIDEO_QUALITY — Maximum simulcast layer granted to guest publishers.
#                              Accepted values: "low" (360p), "medium" (480p), "high" (720p).
#                              Token VideoGrant.VideoQuality is set to this value.
#
GUEST_MAX_PARTICIPANTS=4
GUEST_SESSION_DURATION_MINS=30
GUEST_MAX_VIDEO_QUALITY=medium
